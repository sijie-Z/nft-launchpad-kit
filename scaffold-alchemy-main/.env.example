# Template for shared environment variables between hardhat and nextjs

# To use this template, copy this file, rename it .env, and fill in the values.

# you can override this by setting them individually in those workspaces instead
ALCHEMY_API_KEY=
ALCHEMY_GAS_POLICY_ID=

# Deployer wallet private key (without 0x prefix)
PRIVATE_KEY=

# Etherscan API key for contract verification
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Trusted signer private key for signature mint API (/api/signature)
# This should be the same key as the address set via setTrustedSigner()
# Without 0x prefix
SIGNER_PRIVATE_KEY=