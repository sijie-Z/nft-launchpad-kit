{
  "name": "nft-launchpad-subgraph",
  "version": "1.0.0",
  "description": "The Graph subgraph for NFT Launchpad Kit",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "create-local": "graph create --node http://localhost:8020/ nft-launchpad-kit",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 nft-launchpad-kit",
    "create-sepolia": "graph create --node https://api.thegraph.com/deploy/ sijie-Z/nft-launchpad-kit",
    "deploy-sepolia": "graph deploy --node https://api.thegraph.com/deploy/ --ipfs https://api.thegraph.com/ipfs/ sijie-Z/nft-launchpad-kit",
    "deploy-studio": "graph deploy --studio nft-launchpad-kit"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "0.80.1",
    "@graphprotocol/graph-ts": "0.35.1"
  }
}
